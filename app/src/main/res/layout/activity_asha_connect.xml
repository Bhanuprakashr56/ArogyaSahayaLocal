<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Upcoming Health Events" android:textColor="@color/green_200"
        android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Local camps and ASHA worker visits" android:textColor="#AAFFFFFF"
        android:textSize="14sp" android:layout_marginBottom="16dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAshaEvents"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>
